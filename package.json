{
    "name": "@dre44/nest-dev",
    "version": "0.0.23",
    "description": "",
    "type": "module",
    "scripts": {
        "tc": "tsc --noEmit",
        "tc:watch": "tsc --noEmit --watch",
        "prebuild": "rm -rf dist",
        "build": "tsc",
        "test:build": "tsx src/program.ts build --dir ../../apps/auth-server",
        "test:start": "tsx src/program.ts start --dir ../../apps/auth-server",
        "test:watch": "tsx src/program.ts watch --dir ../../apps/auth-server",
        "test:dev": "tsx src/program.ts dev --dir ../../apps/auth-server"
    },
    "bin": "dist/program.js",
    "main": "./dist/index.js",
    "exports": {
        ".": "./dist/index.js"
    },
    "keywords": [],
    "author": "André Thomas",
    "license": "ISC",
    "devDependencies": {
        "@dotenvx/dotenvx": "^1.44.2",
        "@types/node": "^22.14.1",
        "tsc-alias": "^1.8.16"
    },
    "dependencies": {
        "chokidar": "^4.0.3",
        "commander": "^14.0.0"
    }
}

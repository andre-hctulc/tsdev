{
    "name": "@dre44/tsdev",
    "version": "0.8.0",
    "description": "",
    "type": "module",
    "scripts": {
        "tc": "tsc --noEmit",
        "tc:watch": "tsc --noEmit --watch",
        "prebuild": "rm -rf dist",
        "build": "tsc",
        "test:build": "tsx src/program.ts build -l debug --dir ${APP_DIR}",
        "test:start": "tsx src/program.ts start -l debug --dir ${APP_DIR}",
        "test:watch": "tsx src/program.ts watch -l debug --dir ${APP_DIR}",
        "test:dev": "tsx src/program.ts dev -l debug --dir ${APP_DIR}"
    },
    "bin": "dist/program.js",
    "main": "./dist/index.js",
    "exports": {
        ".": "./dist/index.js"
    },
    "keywords": [],
    "author": "André Thomas",
    "license": "ISC",
    "devDependencies": {
        "@dotenvx/dotenvx": "^1.44.2",
        "@types/node": "^22.19.19"
    },
    "dependencies": {
        "chokidar": "^4.0.3",
        "commander": "^14.0.0",
        "tsc-alias": "^1.8.16"
    }
}
